# Copy to .env and adjust. Never commit real secrets.
# Compose throwaway credentials for local regtest / postgres are documented below.

# --- Network selection (mainnet | testnet | regtest) ---
EXPLORER_NETWORK=regtest

# --- Cyberyen Core JSON-RPC (no defaults for secrets in Settings) ---
# Local compose: cyberyend-regtest listens on host port 18439 (Cyberyen regtest RPC default) with user/pass dev/dev
EXPLORER_RPC_URL=http://127.0.0.1:18439
EXPLORER_RPC_USER=dev
EXPLORER_RPC_PASSWORD=dev

# --- ZMQ notifications from the node ---
EXPLORER_ZMQ_RAWBLOCK=tcp://127.0.0.1:28332
EXPLORER_ZMQ_HASHTX=tcp://127.0.0.1:28333

# --- PostgreSQL (async SQLAlchemy URL) ---
# Local compose: user/password/db are all "explorer" (throwaway)
EXPLORER_DB_URL=postgresql+asyncpg://explorer:explorer@127.0.0.1:5432/explorer

# --- DB schema name (defaults to EXPLORER_NETWORK when unset) ---
EXPLORER_DB_SCHEMA=regtest

# --- Indexer sync tuning ---
EXPLORER_SYNC_POLL_INTERVAL_SEC=60
EXPLORER_MAX_REORG_DEPTH=100
