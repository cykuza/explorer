# Copy to deploy/.env.prod and replace every CHANGE_ME value.
#   cp deploy/.env.prod.example deploy/.env.prod
# Never commit deploy/.env.prod.
#
# Used by: docker compose -f deploy/compose.prod.yml … (auto-loads .env.prod from
# this directory when present; CI copies this example to .env.prod for config -q).
# On the server the file lives at /opt/explorer/.env.prod.

# --- Image tags (optional; compose defaults match these) ---
# CD sets EXPLORER_TAG=<git sha> on the deploy command line without rewriting this file.
EXPLORER_TAG=latest
CYBERYEND_TAG=0.21.6.1

# --- PostgreSQL ---
POSTGRES_USER=explorer
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=explorer

# --- Cyberyen Core RPC (shared by mainnet + testnet nodes in compose) ---
CYBERYEN_RPC_USER=explorer
CYBERYEN_RPC_PASSWORD=CHANGE_ME

# Mainnet P2P seeds are baked into compose.prod.yml as -addnode= (legacy peers that
# survive container recreate). Do NOT point addnode at cyberyen.work — that host is
# the explorer web front door, not a node. Edit compose (or add further -addnode=
# lines) when seed topology changes. Testnet currently has no fixed addnode list.

# --- API tuning (optional; defaults match ApiSettings) ---
EXPLORER_API_MAX_LAG=10
EXPLORER_DB_STATEMENT_TIMEOUT_MS=5000
EXPLORER_API_LIMIT_CONCURRENCY=100
